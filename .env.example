# PulseMagis — Environment Variables
# Copy this file to .env and fill in your values.
# Get both values from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Used only by deploy.ps1 — SSH target for the server to deploy to (user@host-or-ip)
DEPLOY_SERVER=root@your-server-ip
